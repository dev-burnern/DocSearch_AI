APP_NAME=DocSearch AI
APP_ENV=development
DEBUG=false
# 형식: api_key|workspace_id|workspace_name(|role)
# role은 member 또는 admin이며, 생략하면 member로 처리됩니다.
DOCSEARCH_API_KEYS=local-dev-key|local-workspace|Local Workspace|admin;local-member-key|local-workspace|Local Workspace|member
VITE_API_BASE_URL=/api

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=docsearch
POSTGRES_PASSWORD=docsearch
POSTGRES_DB=docsearch
DATABASE_URL=postgresql://docsearch:docsearch@postgres:5432/docsearch
AUDIT_LOG_BACKEND=postgres
DOCUMENT_METADATA_BACKEND=postgres
DOCUMENT_MAX_BYTES=10485760

REDIS_URL=redis://redis:6379/0
DEPENDENCY_HEALTH_CHECKS_ENABLED=false
DEPENDENCY_HEALTH_TIMEOUT_SECONDS=2.0
RATE_LIMIT_ENABLED=false
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REDIS_PREFIX=docsearch:rate-limit
RATE_LIMIT_FAIL_OPEN=true

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=docsearch_chunks

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=documents
MINIO_SECURE=false
INDEXING_QUEUE_BACKEND=inprocess
INDEXING_QUEUE_REDIS_KEY=docsearch:indexing:queue
INDEXING_QUEUE_MAX_ATTEMPTS=3
CHUNK_MAX_CHARACTERS=1000
CHUNK_OVERLAP_CHARACTERS=100
EMBEDDING_VECTOR_SIZE=8
EMBEDDING_BACKEND=deterministic
EMBEDDING_BASE_URL=http://embedding:8002/v1
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=10.0

LLM_BASE_URL=http://llm:8000/v1
LLM_MODEL=google/gemma-4-E4B-it
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30.0
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=0.5
CHAT_RETRIEVAL_LIMIT=5
CHAT_RERANK_TOP_K=5
CHAT_MIN_RELEVANCE_SCORE=0.2
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_BACKEND=score
RERANKER_BASE_URL=http://reranker:8001/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_API_KEY=
RERANKER_TIMEOUT_SECONDS=10.0
