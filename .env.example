# DocSearch AI Server 환경 변수 설정
# 프로덕션 환경에서는 적절히 수정하세요

# ============================================================
# 기본 설정
# ============================================================
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# ============================================================
# PostgreSQL 데이터베이스
# ============================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=docsearch
POSTGRES_PASSWORD=docsearch_password_change_me
POSTGRES_DB=docsearch
DATABASE_URL=postgresql+asyncpg://docsearch:docsearch_password_change_me@postgres:5432/docsearch

# ============================================================
# Redis
# ============================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_change_me
REDIS_URL=redis://:redis_password_change_me@redis:6379/0

# ============================================================
# Qdrant 벡터 데이터베이스
# ============================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# ============================================================
# MinIO 객체 스토리지
# ============================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key_change_me
MINIO_BUCKET=documents
MINIO_SECURE=false

# ============================================================
# Ollama LLM
# ============================================================
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# ============================================================
# 임베딩 모델 설정
# ============================================================
EMBED_MODEL=BAAI/bge-m3
EMBED_DEVICE=cuda
EMBED_DIM=1024
EMBED_BATCH_SIZE=16

# ============================================================
# 리랭커 모델 설정
# ============================================================
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_DEVICE=cuda
RERANK_BATCH_SIZE=32

# ============================================================
# 청킹 설정
# ============================================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_CHUNKS_PER_DOC=2000

# ============================================================
# 파일 업로드 설정
# ============================================================
MAX_FILE_SIZE_MB=100
ALLOWED_EXTENSIONS=.pdf,.docx,.xlsx,.pptx,.txt,.md,.hwp,.png,.jpg,.jpeg

# ============================================================
# JWT 인증 설정
# ============================================================
JWT_SECRET=jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# CORS 설정
# ============================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================
# Celery Worker 설정
# ============================================================
CELERY_BROKER_URL=redis://:redis_password_change_me@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_password_change_me@redis:6379/1
